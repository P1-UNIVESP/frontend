  <script>
    let dados = JSON.parse(localStorage.getItem('dados')) || [];
    let editandoId = null;

    function salvar() {
      const nome = document.getElementById('nome').value;
      const falecimento = document.getElementById('falecimento').value;
      const jazigo = document.getElementById('jazigo').value;

      if (!nome) return alert('Digite um nome');

      if (editandoId !== null) {
        const item = dados.find(d => d.id === editandoId);
        item.nome = nome;
        item.falecimento = falecimento;
        item.jazigo = jazigo;
        editandoId = null;
      } else {
        dados.push({
          id: Date.now(),
          nome,
          falecimento,
          jazigo
        });
      }

      localStorage.setItem('dados', JSON.stringify(dados));
      limpar();
      renderizar();
    }

